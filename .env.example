# ── 日志级别 ──
LOG_LEVEL=DEBUG

# ── Ollama 本地模型 ──
OLLAMA_BASE_URL=

# ── Brain 配置 ──
BRAIN=                  # local / llm / ollama
LLM_MODEL=              # 模型名，如 qwen3.6-flash、gpt-4o
LLM_KEY=                # API Key
LLM_URL=                # API 地址，如 https://dashscope.aliyuncs.com/compatible-mode/v1

VISION_ENABLED=false    # 模型是否支持 vision，开启后截图合并为多模态调用
VISION_SCALE=1           # 截图缩放比例（1=不缩放，锁下限1536px）

# 额外 prompt（追加到硬编码的决策提示后，可选；支持 {context} 占位符）
NON_VISION_PROMPT_EXTRA=
VISION_PROMPT_EXTRA=

# ── VIEW：屏幕分析（调试面板独立分析用）──
VIEW_PROMPT_SYSTEM=你是桌面宠物的视觉分析模块。任务：分析屏幕截图，输出结构化的桌面环境描述。
VIEW_PROMPT_VISION=请描述这张截图中的内容，用户可能在做什么？

# ── OCR 屏幕文字提取 ──
OCR_ENABLED=false
OCR_GPU=false
OCR_LANGUAGES=ch_sim,en
OCR_MAX_CHARS=500

# ── LLM 超时与重试 ──
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1
LLM_RETRY_MAX_DELAY=8

# ── 技能插件 ──
# 启用的技能插件，逗号分隔，* = 全部启用，留空 = 全部禁用
SKILLS_ENABLED=system_monitor,browser,file

# ── 宠物人格 ──
PET_PERSONALITY=你是一只活泼好动的Q版小猫，充满好奇心，喜欢在窗口之间跳来跳去。说话俏皮，带点傲娇。

# ── Agent 调度 ──
SCHEDULER_AUTO_START=false
SCHEDULER_FAST_MS=1000
SCHEDULER_MID_MS=30000
SCHEDULER_SLOW_MS=300000

#动作最大持续时间
ACTION_TIMEOUT_MS=15000

#是否显示系统托盘
SHOW_TRAY=true
