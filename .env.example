# ── Ollama 本地模型 ──
OLLAMA_BASE_URL=

# ── 统一 Brain 配置 ──
# 单个 LLM 同时输出"动作 + 语言"行为序列，无需外部编排
BRAIN=                  # local / llm / ollama
LLM_MODEL=              # 模型名，如 deepseek-v4-pro
LLM_KEY=                # API Key
LLM_URL=                # API 地址，如 https://api.deepseek.com

BEHAVIOR_PROMPT_SYSTEM=
BEHAVIOR_PROMPT_DECIDE=

# ── Chat 对话提示（复用同一 LLM） ──
CHAT_PROMPT_SYSTEM=
CHAT_PROMPT_GREET=

# ── VIEW：屏幕分析 / 视觉模型（需支持 vision 的模型，如 GLM-4V） ──
VIEW_BRAIN=
VIEW_MODEL=
VIEW_MODEL_KEY=
VIEW_MODEL_URL=
VIEW_PROMPT_SYSTEM=
VIEW_PROMPT_VISION=
