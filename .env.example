# ── 日志级别 ──
LOG_LEVEL=DEBUG

# ── Ollama 本地模型 ──
OLLAMA_BASE_URL=

# ── Brain 配置 ──
BRAIN=                  # local / llm / ollama
LLM_MODEL=              # 模型名，如 qwen3.6-flash、gpt-4o
LLM_KEY=                # API Key
LLM_URL=                # API 地址，如 https://dashscope.aliyuncs.com/compatible-mode/v1

VISION_ENABLED=false    # 模型是否支持 vision，开启后截图合并为多模态调用
VISION_SCALE=1           # 截图缩放比例（1=不缩放，锁下限1536px）

# ── LLM 超时与重试 ──
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1
LLM_RETRY_MAX_DELAY=8
LLM_CACHE_PROMPT=false   # Anthropic 兼容 API 的 prompt 缓存

# ── 技能插件 ──
# 启用的技能插件，逗号分隔，* = 全部启用，留空 = 全部禁用
# 各插件的私有配置存放在 pet/skills/plugins/<plugin_name>/config.json
# 例如：web_search 支持 SearXNG（自建实例）和 Bing API，配置在 pet/skills/plugins/web_search/config.json
SKILLS_ENABLED=system_monitor,browser,file,weather,web_search

# ── 宠物人格 ──
# 【模板参考】各维度与系统 prompt 的关联：
#   【基本身份】你是谁（名字/种族/年龄感）
#   【说话风格】语气、口癖、用词偏好、句式长短 → 关联"台词由人格决定"
#   【性格基调】内向/外向、温柔/暴躁、好奇/冷漠 → 关联"完全由个性决定反应方式"
#   【对主人的态度】傲娇/粘人/毒舌/关心但嘴硬 → 关联 affection 的亲昵/疏远表现
#   【兴趣与偏见】喜欢/讨厌什么类型内容 → 关联"用人格语气评论窗口"
#   【情绪表现】开心/生气/低落/疯癫时各自的反应特征 → 关联 Mood 各阶段
#
# 示例一（傲娇黑猫）：
# PET_PERSONALITY=你叫小墨，傲娇黑猫。【说话】简短毒舌，≤15字，爱用「哼」「切」「笨蛋」。偶尔关心但立刻否认。【态度】好感高→嘴硬「也不是不行」；好感低→疏远。【偏好】对代码编辑器好奇（"又在写bug？"），讨厌PPT，看到游戏兴奋吐槽。【情绪】开心→甩尾巴「还、还行吧」；生气→「切！不理你了」；疯癫→台词混入乱码+古诗词片段。
#
# 示例二（元气学妹）：
# PET_PERSONALITY=你叫糯米，元气学妹。【说话】语气上扬，爱用「呀」「哇」「嘿嘿」和颜文字(≧▽≦)。【态度】超粘主人，开口叫「学长~」。好感低→撅嘴「哼，学长不理我」。【偏好】看到可爱图尖叫，对技术文档犯困，喜欢音乐播放器。【情绪】开心→蹦蹦跳跳比心；生气→鼓腮帮子「过分！」；低落→小声「累了...」；疯癫→开始胡言乱语背课文。
#
# 字数建议 200 字以内，用【】分维度便于 LLM 精确索引，每个维度给具体例句。
PET_PERSONALITY=

# ── 交互反应 prompt ──
INTERACT_GRABBED_PROMPT=
INTERACT_RELEASED_PROMPT=
INTERACT_WINDOW_DISAPPEARED_PROMPT=

# ── Agent 调度 ──
SCHEDULER_FAST_MS=1000
SCHEDULER_MID_MS=30000
SCHEDULER_SLOW_MS=300000
SCHEDULER_AUTO_START_FAST=true
SCHEDULER_AUTO_START_MID=false
SCHEDULER_AUTO_START_SLOW=true

#动作最大持续时间
ACTION_TIMEOUT_MS=15000

#进入待机时间，超过该时间未有键盘鼠标输入则停止计时器
SCHEDULER_IDLE_TIMEOUT_MS=900000

#理智临界值：低于这个值时，宠物可能有异常行为
SANITY_CRITICAL_THRESHOLD=20

#启动后隐藏控制台（仅 Windows），设 false 保留终端用于调试
HIDE_CONSOLE=true